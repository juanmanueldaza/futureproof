# FutureProof Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider (pick ONE — auto-detected from available keys if empty)
# =============================================================================

# Option 1: FutureProof Proxy (DEFAULT — zero config, free starter tokens)
# Sign up at: https://fu7ur3pr00f.dev/signup
# FUTUREPROOF_PROXY_KEY=fp-...

# Option 2: OpenAI
# OPENAI_API_KEY=sk-...

# Option 3: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option 4: Google Gemini
# GOOGLE_API_KEY=...

# Option 5: Azure OpenAI / AI Foundry
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_CHAT_DEPLOYMENT=gpt-4.1
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Option 6: Ollama (local, free, offline)
# Install: https://ollama.com/download
# Pull a model: ollama pull qwen3
# OLLAMA_BASE_URL=http://localhost:11434

# Force a specific provider (bypasses auto-detection)
# LLM_PROVIDER=openai

# =============================================================================
# Purpose-Based Model Routing (optional — overrides default fallback chain)
# =============================================================================

# Provider-agnostic (works with any provider)
# AGENT_MODEL=gpt-5-mini           # Tool calling
# ANALYSIS_MODEL=gpt-4.1           # Analysis / CV generation
# SUMMARY_MODEL=gpt-4o-mini        # Summarization
# SYNTHESIS_MODEL=o4-mini           # Synthesis (reasoning)
# EMBEDDING_MODEL=text-embedding-3-small

# Legacy Azure-specific (backward compat, prefer above)
# AZURE_AGENT_DEPLOYMENT=
# AZURE_ANALYSIS_DEPLOYMENT=
# AZURE_SUMMARY_DEPLOYMENT=

# =============================================================================
# Data Gathering Configuration
# =============================================================================

# Portfolio URL to scrape
PORTFOLIO_URL=https://your-portfolio.com

# =============================================================================
# MCP (Model Context Protocol) Configuration - Optional
# When configured, enables real-time data access instead of CLI-based gathering
# =============================================================================

# GitHub MCP Server
# Create token at: https://github.com/settings/tokens
# Required scopes: repo, read:user, user:email
# Username is auto-discovered via MCP and saved to profile.yaml
GITHUB_PERSONAL_ACCESS_TOKEN=

# Set to false to use native binary instead of Docker
# GITHUB_MCP_COMMAND=github-mcp-server  # Native binary

# GitLab access via glab CLI (auth handled by: glab auth login)
# Install: https://gitlab.com/gitlab-org/cli

# =============================================================================
# Market Intelligence Configuration - Optional
# Most sources require NO configuration (JobSpy, HN, RemoteOK, etc.)
# =============================================================================

# Tavily Search API Key (for salary data and market research)
# Get your free key at: https://tavily.com/ (1,000 queries/month, no credit card)
TAVILY_API_KEY=

# Disable specific sources if needed (all enabled by default)
# JOBSPY_ENABLED=true
# HN_MCP_ENABLED=true

# Cache durations (hours)
# MARKET_CACHE_HOURS=24
# JOB_CACHE_HOURS=12
# CONTENT_CACHE_HOURS=12

# =============================================================================
# Knowledge Base Configuration - Optional
# =============================================================================

# Auto-index career data after gathering (default: true)
KNOWLEDGE_AUTO_INDEX=true

# Chunking settings for RAG
KNOWLEDGE_CHUNK_MAX_TOKENS=500
KNOWLEDGE_CHUNK_MIN_TOKENS=50

# =============================================================================
# LLM Settings - Optional
# =============================================================================

# LLM_TEMPERATURE=0.3          # General temperature (0.0-1.0)
# CV_TEMPERATURE=0.2           # CV generation temperature (lower = more consistent)
