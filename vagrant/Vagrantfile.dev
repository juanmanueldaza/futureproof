# -*- mode: ruby -*-
# vi: set ft=ruby :

# Development Vagrantfile for FutureProof
# Usage:
#   cd vagrant
#   VAGRANT_VAGRANTFILE=Vagrantfile.dev vagrant up --provision
#   VAGRANT_VAGRANTFILE=Vagrantfile.dev vagrant ssh
#
# Or use the helper script:
#   scripts/vagrant_dev_setup.sh up
#
# Environment variables:
#   VAGRANT_BOX         - Box to use (default: "bento/ubuntu-24.04")
#   VAGRANT_VM_MEMORY   - RAM in MB (default: 4096)
#   VAGRANT_VM_CPUS     - CPU cores (default: 2)

Vagrant.configure("2") do |config|
  config.vm.box = ENV.fetch("VAGRANT_BOX", "bento/ubuntu-24.04")
  config.vm.hostname = "fu7ur3pr00f-dev"
  config.vm.boot_timeout = 600

  # Sync the entire project directory
  config.vm.synced_folder "..", "/workspace"

  # Sync your local .env file (contains secrets)
  config.vm.synced_folder "#{Dir.home}/.fu7ur3pr00f", "/home/vagrant/.fu7ur3pr00f",
    create: true,
    owner: "vagrant",
    group: "vagrant",
    mount_options: ["dmode=755,fmode=644"]

  # Optional: Sync specific data directories if not in project
  # config.vm.synced_folder "~/my-career-data", "/workspace/data/raw"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = ENV.fetch("VAGRANT_VM_MEMORY", 4096).to_i
    vb.cpus = ENV.fetch("VAGRANT_VM_CPUS", 2).to_i
  end

  # Install development dependencies
  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    set -euo pipefail

    LOG_FILE="/home/vagrant/provision.log"
    exec > >(tee -a "${LOG_FILE}") 2>&1

    log() {
      echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    }

    log "=== Starting provision ==="
    log "LOG_FILE=${LOG_FILE}"
    log "PWD=$(pwd)"
    log "USER=${USER:-unknown}"

    log "=== Installing system dependencies ==="
    # Add deadsnakes PPA for Python 3.13
    log "Adding deadsnakes PPA for Python 3.13..."
    sudo apt-get update
    sudo apt-get install -y software-properties-common
    sudo add-apt-repository -y ppa:deadsnakes/ppa
    sudo apt-get update
    
    sudo apt-get install -y \
      git \
      curl \
      wget \
      build-essential \
      libpango-1.0-0 \
      libpangoft2-1.0-0 \
      libcairo2 \
      libfontconfig1 \
      libgdk-pixbuf-2.0-0 \
      poppler-utils \
      glab \
      python3.13 \
      python3.13-venv \
      python3.13-dev

    log "=== Setting up Python virtual environment ==="
    cd /workspace
    log "Workspace contents:"
    ls -la || true
    
    # Always start with a clean venv to avoid corruption issues
    log "Removing any existing .venv..."
    rm -rf .venv
    
    log "Creating new venv with python3.13 -m venv .venv"
    if ! python3.13 -m venv .venv; then
      log "ERROR: Failed to create venv"
      exit 1
    fi
    
    log "Verifying venv..."
    if [ ! -f .venv/bin/python ]; then
      log "ERROR: .venv/bin/python not found"
      exit 1
    fi
    
    log "VenV python version: $(.venv/bin/python --version)"

    log "=== Installing project dependencies ==="
    # Skip pip upgrade - it can corrupt itself in Vagrant synced folders
    # Use the bundled pip which is sufficient
    log "Using bundled pip (skipping upgrade to avoid corruption)..."
    
    log "Installing build tools first (hatchling for editable install)..."
    if ! .venv/bin/python -m pip install hatchling --quiet 2>&1 | tee -a "${LOG_FILE}"; then
      log "ERROR: Failed to install hatchling"
      exit 1
    fi
    
    log "Installing project in editable mode..."
    if ! .venv/bin/python -m pip install -e . 2>&1 | tee -a "${LOG_FILE}"; then
      log "ERROR: Failed to install project"
      log "Checking pyproject.toml..."
      cat pyproject.toml || true
      exit 1
    fi
    
    log "Installing dev tools (pyright, pytest, ruff)..."
    if ! .venv/bin/python -m pip install pyright pytest ruff 2>&1 | tee -a "${LOG_FILE}"; then
      log "ERROR: Failed to install dev tools"
      exit 1
    fi
    
    log "Verifying installation..."
    .venv/bin/fu7ur3pr00f --version || log "WARNING: fu7ur3pr00f not in PATH yet"

    log "=== Installing GitHub MCP server ==="
    if ! command -v github-mcp-server &> /dev/null; then
      GITHUB_MCP_VERSION="v0.1.0"
      log "Downloading GitHub MCP server ${GITHUB_MCP_VERSION}..."
      if ! curl -fsSL "https://github.com/github/github-mcp-server/releases/download/${GITHUB_MCP_VERSION}/github-mcp-server_Linux_x86_64.tar.gz" | \
        sudo tar xzf - -C /usr/local/bin github-mcp-server; then
        log "ERROR: Failed to install GitHub MCP server"
        exit 1
      fi
      log "GitHub MCP server installed successfully"
    else
      log "GitHub MCP server already installed"
    fi

    log "=== Auto-gathering career data ==="
    RAW_DIR="/home/vagrant/.fu7ur3pr00f/data/raw"
    mkdir -p "${RAW_DIR}"

    # Count data files
    ZIP_COUNT=$(find "${RAW_DIR}" -maxdepth 1 -name "*.zip" 2>/dev/null | wc -l)
    PDF_COUNT=$(find "${RAW_DIR}" -maxdepth 1 -name "*.pdf" 2>/dev/null | wc -l)
    MD_COUNT=$(find "${RAW_DIR}"  -maxdepth 1 -name "*.md"  2>/dev/null | wc -l)
    TXT_COUNT=$(find "${RAW_DIR}" -maxdepth 1 -name "*.txt" 2>/dev/null | wc -l)
    TOTAL_FILES=$(( ZIP_COUNT + PDF_COUNT + MD_COUNT + TXT_COUNT ))

    log "Data files found in ${RAW_DIR}:"
    log "  - ZIP (LinkedIn exports): ${ZIP_COUNT}"
    log "  - PDF (CliftonStrengths/CV): ${PDF_COUNT}"
    log "  - Markdown (CV): ${MD_COUNT}"
    log "  - Text (CV): ${TXT_COUNT}"
    log "  - Total: ${TOTAL_FILES}"

    if [ "${TOTAL_FILES}" -gt 0 ]; then
      log "Running gather — this may take a minute..."
      cd /workspace
      .venv/bin/python - <<'PYEOF' 2>&1 | tee -a "${LOG_FILE}"
import logging
import sys

# Stream INFO to stdout so Vagrant captures it in the provision log
logging.basicConfig(
    level=logging.INFO,
    format="[%(asctime)s] %(levelname)s %(name)s: %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
    handlers=[logging.StreamHandler(sys.stdout)],
)

logger = logging.getLogger("gather")
logger.info("Starting GathererService...")

try:
    from fu7ur3pr00f.services.gatherer_service import GathererService

    service = GathererService()
    logger.info("GathererService created — starting gather_all()...")

    sections = service.gather_all()

    by_source: dict[str, int] = {}
    for s in sections:
        src = getattr(s, "source", getattr(s, "name", "unknown"))
        by_source[src] = by_source.get(src, 0) + 1

    logger.info("Gather complete — %d sections indexed", len(sections))
    for src, count in sorted(by_source.items()):
        logger.info("  %-30s %d chunks", src, count)

    sys.exit(0)
except ImportError as exc:
    logger.warning("GathererService import failed (%s), trying direct gatherers...", exc)

    from pathlib import Path

    from fu7ur3pr00f.gatherers.cliftonstrengths import CliftonStrengthsGatherer
    from fu7ur3pr00f.gatherers.cv import CVGatherer
    from fu7ur3pr00f.gatherers.linkedin import LinkedInGatherer

    data_dir = Path("/home/vagrant/.fu7ur3pr00f/data/raw")
    total = 0

    for zip_file in data_dir.glob("*.zip"):
        logger.info("LinkedIn: processing %s", zip_file.name)
        sections = LinkedInGatherer().gather(zip_file)
        total += len(sections)
        logger.info("LinkedIn: %d sections indexed", len(sections))

    pdf_strength_files = [
        f for f in data_dir.glob("*.pdf")
        if any(kw in f.name.lower() for kw in
               ("strength", "gallup", "clifton", "top_5", "top_10", "all_34"))
    ]
    if pdf_strength_files:
        logger.info("CliftonStrengths: processing %d PDF(s)...", len(pdf_strength_files))
        sections = CliftonStrengthsGatherer().gather(data_dir)
        total += len(sections)
        logger.info("CliftonStrengths: %d sections indexed", len(sections))

    for cv_file in list(data_dir.glob("*.md")) + list(data_dir.glob("*.txt")):
        logger.info("CV: processing %s", cv_file.name)
        try:
            sections = CVGatherer().gather(cv_file)
            total += len(sections)
            logger.info("CV: %d sections indexed from %s", len(sections), cv_file.name)
        except Exception as err:
            logger.warning("CV: skipping %s — %s", cv_file.name, err)

    logger.info("Direct gather complete — %d sections total", total)
    sys.exit(0)
except Exception as exc:
    logger.error("Gather failed: %s", exc, exc_info=True)
    sys.exit(1)
PYEOF

      if [ $? -eq 0 ]; then
        log "Gather completed successfully."
      else
        log "WARNING: Gather encountered errors — check the log above."
        log "You can re-run inside the VM with: cd /workspace && source .venv/bin/activate && fu7ur3pr00f (then /gather)"
      fi
    else
      log "No data files found — skipping gather."
      log "To gather later, place files in ${RAW_DIR} and run /gather in the chat."
    fi

    log "=== Provision complete ==="
    log ""
    log "To start the FutureProof chat:"
    log "  cd /workspace"
    log "  source .venv/bin/activate"
    log "  fu7ur3pr00f"
    log ""
    log "Your data is at: ${RAW_DIR}"
    log "Your config is at: /home/vagrant/.fu7ur3pr00f/.env"
    log "Provision log saved to: ${LOG_FILE}"
  SHELL
end
